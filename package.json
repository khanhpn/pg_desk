{
  "name": "PgDesk",
  "description": "A lightweight PostgreSQL desktop client",
  "author": "Khanh Pham",
  "private": true,
  "version": "0.1.31",
  "type": "module",
  "engines": {
    "node": "24.15.0"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "predev": "pnpm run docs:sync-version",
    "dev": "vite",
    "prebuild": "pnpm run docs:sync-version",
    "build": "tsc && vite build",
    "docs:sync-version": "node scripts/sync-docs-version.mjs",
    "release:mac": "pnpm run build && electron-builder --mac --x64 --arm64 --publish never",
    "release:mac:intel": "pnpm run build && electron-builder --mac --x64 --publish never",
    "release:win": "pnpm run build && electron-builder --win nsis --publish never",
    "release": "pnpm run build && electron-builder --publish never",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:install": "node node_modules/electron/install.js",
    "test:e2e": "pnpm run electron:install && pnpm run build && playwright test",
    "test:e2e:run": "playwright test",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "preview": "vite preview"
  },
  "dependencies": {
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/view": "^6.43.3",
    "@uiw/codemirror-theme-github": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.10",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "pg": "^8.22.0",
    "pg-connection-string": "2.14.0",
    "pg-int8": "1.0.1",
    "pg-pool": "3.14.0",
    "pg-protocol": "1.15.0",
    "pg-types": "2.2.0",
    "pgpass": "1.0.5",
    "postgres-array": "2.0.0",
    "postgres-bytea": "1.0.1",
    "postgres-date": "1.0.7",
    "postgres-interval": "1.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "split2": "4.2.0",
    "xtend": "4.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^1.6.1"
  },
  "main": "dist-electron/main.js",
  "lint-staged": {
    "{src,electron}/**/*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings 0"
    ],
    "vite.config.ts": [
      "prettier --write",
      "eslint --fix --max-warnings 0"
    ],
    "*.{css,json,md,html}": "prettier --write"
  }
}
